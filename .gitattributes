# Normalize line endings: store LF in the repo, let Git convert on checkout.
* text=auto

# Files that must keep LF even on Windows checkouts
*.sh text eol=lf

# Windows-specific files that must keep CRLF
*.bat text eol=crlf
*.rc text eol=crlf

# Binary assets — never touch line endings
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.ttf binary
*.otf binary
*.jar binary
